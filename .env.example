# Google Sheets (for flow nodes)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=...

# Auto-reconnect when WhatsApp disconnects (true/false)
# AUTO_RECONNECT_ON_DISCONNECT=false

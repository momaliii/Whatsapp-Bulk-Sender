# Server
PORT=3000
TZ=Africa/Cairo

# Paths
DATA_DIR=./data
UPLOAD_DIR=./uploads

# Chrome/Chromium for WhatsApp Web (optional - auto-detected if not set)
# CHROME_PATH=/usr/bin/chromium

# OpenAI for AI Agent
